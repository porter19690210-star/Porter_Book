---
const {
  title = "",
  currentSlug = "",
  description = "Claude Code 完整指南 — 從入門到進階，包含 Skills、Hooks、MCP Plugin",
  prevChapter = null,
  nextChapter = null,
} = Astro.props;

import { navigation } from '../data/navigation.js';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const currentPart = navigation.find(p =>
  p.chapters.some(ch => ch.slug === currentSlug)
)?.part ?? 0;

// Auto-open parts that contain current chapter or parts 1-3 (MVP content)
function isPartOpen(part) {
  return part.part === currentPart || part.part <= 3;
}
---
<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{title ? `${title} | ` : ""}Claude Code 完整指南</title>
  <meta name="description" content={description}>
  <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml">
  <script is:inline>
    (function () {
      const s = localStorage.getItem('cc-theme');
      const d = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (s === 'dark' || (!s && d)) document.documentElement.classList.add('dark');
    })();
  </script>
  <style>
    /* ── Variables ──────────────────────────────────────────── */
    :root {
      --bg:       #faf9f7;
      --bg2:      #f0ede6;
      --bg3:      #e8e2d8;
      --border:   #ddd8cc;
      --text:     #1a1908;
      --text2:    #3d3930;
      --muted:    #6b6558;
      --accent:   #c0533a;
      --accent2:  #e06b4a;
      --abg:      rgba(192,83,58,.07);
      --code-bg:  #1e1e1e;
      --code-fg:  #d4d4d4;
      --sw:       260px;
      --hh:       60px;
      --mono: 'Fira Code','Cascadia Code','Consolas',monospace;
      --serif: Georgia,'Noto Serif TC',serif;
      --sans: system-ui,-apple-system,'Segoe UI',sans-serif;
    }
    html.dark {
      --bg:#0f0e0d; --bg2:#1a1916; --bg3:#252320;
      --border:#333; --text:#f0ede6; --text2:#ccc8be; --muted:#888;
      --accent:#e07050; --accent2:#f08060; --abg:rgba(224,112,80,.1);
      --code-bg:#111;
    }

    /* ── Reset ──────────────────────────────────────────────── */
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth}
    body{font-family:var(--sans);background:var(--bg);color:var(--text);line-height:1.75;transition:background .2s,color .2s}

    /* ── Progress bar ───────────────────────────────────────── */
    #pb{position:fixed;top:0;left:0;height:3px;width:0%;background:var(--accent);z-index:999;transition:width .08s linear}

    /* ── Header ─────────────────────────────────────────────── */
    header{position:sticky;top:0;height:var(--hh);background:rgba(250,249,247,.92);border-bottom:1px solid var(--border);backdrop-filter:blur(8px);z-index:100;transition:background .2s}
    html.dark header{background:rgba(15,14,13,.92)}
    .hi{display:flex;align-items:center;justify-content:space-between;height:100%;padding:0 1rem;max-width:90rem;margin:0 auto}
    .hl{display:flex;align-items:center;gap:.75rem}
    .logo{width:30px;height:30px;background:var(--accent);border-radius:7px;display:flex;align-items:center;justify-content:center;color:#fff;font-size:.7rem;font-weight:700;font-family:var(--mono);flex-shrink:0}
    .site-name{font-size:.9rem;font-weight:600;color:var(--text);text-decoration:none;letter-spacing:-.02em}
    .site-name:hover{color:var(--accent)}
    .hr{display:flex;align-items:center;gap:.4rem}
    .ibtn{width:36px;height:36px;display:flex;align-items:center;justify-content:center;border:none;background:none;cursor:pointer;color:var(--text);border-radius:8px;transition:background .15s,color .15s;flex-shrink:0}
    .ibtn:hover{background:var(--bg2);color:var(--accent)}
    #mbtn{display:none}

    /* ── Layout ─────────────────────────────────────────────── */
    #layout{display:flex;max-width:90rem;margin:0 auto}

    /* ── Sidebar ─────────────────────────────────────────────── */
    #sb{width:var(--sw);flex-shrink:0;height:calc(100vh - var(--hh));position:sticky;top:var(--hh);overflow-y:auto;padding:1.25rem .75rem;border-right:1px solid var(--border)}
    #sb::-webkit-scrollbar{width:3px}
    #sb::-webkit-scrollbar-thumb{background:var(--border);border-radius:2px}
    .np{margin-bottom:.75rem}
    .pt{display:flex;align-items:center;justify-content:space-between;width:100%;background:none;border:none;cursor:pointer;color:var(--muted);font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;padding:.3rem .5rem;border-radius:6px;transition:color .15s,background .15s}
    .pt:hover{color:var(--accent);background:var(--abg)}
    .pt .arr{transition:transform .2s;flex-shrink:0}
    .pt.open .arr{transform:rotate(90deg)}
    .nl{list-style:none;margin-top:.2rem}
    .nl.closed{display:none}
    .nl a{display:flex;align-items:flex-start;gap:.35rem;padding:.38rem .5rem;border-radius:6px;text-decoration:none;color:var(--text2);font-size:.81rem;transition:background .15s,color .15s;line-height:1.45}
    .nl a:hover:not(.cs){background:var(--bg2);color:var(--text)}
    .nl a.active{background:var(--abg);color:var(--accent);font-weight:500}
    .nl a.cs{color:var(--muted);cursor:default;opacity:.65}
    .cn{font-size:.68rem;color:var(--muted);flex-shrink:0;min-width:18px;margin-top:.05rem}
    .bs{font-size:.6rem;padding:.1rem .3rem;border-radius:3px;background:var(--bg3);color:var(--muted);margin-left:auto;flex-shrink:0;white-space:nowrap}

    /* ── Content ─────────────────────────────────────────────── */
    main{flex:1;min-width:0;padding:2.5rem 3rem 5rem}
    .cb{max-width:740px}

    /* ── Chapter nav ─────────────────────────────────────────── */
    .cnav{display:flex;justify-content:space-between;gap:1rem;margin-top:4rem;padding-top:2rem;border-top:1px solid var(--border);max-width:740px}
    .cnav a{flex:1;display:flex;flex-direction:column;padding:.9rem 1.1rem;border:1px solid var(--border);border-radius:10px;text-decoration:none;color:var(--text2);transition:border-color .15s,background .15s}
    .cnav a:hover{border-color:var(--accent);background:var(--abg)}
    .cnav a.next{text-align:right}
    .nd{font-size:.7rem;color:var(--muted);margin-bottom:.2rem;text-transform:uppercase;letter-spacing:.06em;font-weight:500}
    .nt{font-size:.88rem;font-weight:500;color:var(--accent)}
    .ph{flex:1}

    /* ── Mobile ──────────────────────────────────────────────── */
    #ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:90}
    @media(max-width:768px){
      #mbtn{display:flex}
      #sb{position:fixed;top:0;left:0;width:var(--sw);height:100vh;z-index:95;transform:translateX(-100%);transition:transform .25s;padding-top:.75rem;background:var(--bg)}
      #sb.open{transform:translateX(0)}
      #ov.open{display:block}
      main{padding:1.5rem 1.25rem 4rem}
    }
    @media (min-width:769px) and (max-width:1024px){main{padding:2rem 2rem 4rem}}
  </style>

  <style is:global>
    /* ── Typography (slot content — must be global) ─────────── */
    .cb .clabel{font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--accent);margin-bottom:.4rem}
    .cb h1{font-size:1.95rem;font-weight:700;font-family:var(--serif);line-height:1.3;letter-spacing:-.02em;margin-bottom:.4rem}
    .cb .cdesc{font-size:.95rem;color:var(--muted);margin-bottom:2rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
    .cb h2{font-size:1.3rem;font-weight:600;font-family:var(--serif);margin-top:3rem;margin-bottom:.8rem;padding:1.5rem 0 .6rem;border-top:1px solid var(--border);border-bottom:2px solid var(--accent);color:var(--text)}
    .cb .cdesc + h2,.cb h1 + h2{border-top:none;padding-top:0;margin-top:2rem}
    .cb h3{font-size:1.05rem;font-weight:600;margin-top:1.75rem;margin-bottom:.5rem;color:var(--text)}
    .cb p{color:var(--text2);margin-bottom:1rem}
    .cb ul,.cb ol{padding-left:1.5rem;margin-bottom:1rem;color:var(--text2)}
    .cb li{margin-bottom:.3rem}
    .cb li::marker{color:var(--accent)}
    .cb strong{color:var(--text);font-weight:600}
    .cb a{color:var(--accent);text-decoration:none}
    .cb a:hover{text-decoration:underline}
    .cb hr{border:none;border-top:1px solid var(--border);margin:2rem 0}
    .cb kbd{font-family:var(--mono);font-size:.8em;background:var(--bg3);border:1px solid var(--border);border-radius:4px;padding:.1em .4em}

    /* ── Code ───────────────────────────────────────────────── */
    .cb code{font-family:var(--mono);font-size:.83em;background:var(--bg2);padding:.13em .38em;border-radius:4px;color:var(--accent)}
    .cb pre{background:var(--code-bg);color:var(--code-fg);border-radius:10px;padding:1.1rem 1.3rem;overflow-x:auto;margin-bottom:1.25rem;font-size:.83rem;line-height:1.65;font-family:var(--mono)}
    .cb pre code{background:none;padding:0;color:inherit;font-size:inherit}

    /* ── Tables ─────────────────────────────────────────────── */
    .cb table{width:100%;border-collapse:collapse;margin:1.5rem 0;font-size:.9rem;border-top:1px solid var(--border)}
    .cb th{text-align:left;font-weight:600;padding:.7rem 1rem;font-size:.82rem;text-transform:uppercase;letter-spacing:.04em;color:var(--text);border-bottom:2px solid var(--accent)}
    .cb td{padding:.6rem 1rem;border-bottom:1px solid var(--border);color:var(--text2);vertical-align:top;transition:background .12s,color .12s}
    html.dark .cb td{border-bottom-color:#3a3630}
    .cb tbody tr:last-child td{border-bottom:none}
    .cb tbody tr:hover td{background:var(--bg2);color:var(--text)}
    html.dark .cb tbody tr:hover td{background:var(--bg3)}

    /* ── Callout ─────────────────────────────────────────────── */
    .call{display:flex;gap:.75rem;padding:.9rem 1.1rem;border-radius:8px;margin-bottom:1.25rem;font-size:.88rem;border:1px solid}
    .ci{flex-shrink:0;font-size:1rem;margin-top:.1rem}
    .call p{margin:0;color:var(--text2)}
    .call strong{display:block;margin-bottom:.2rem}
    .tip{background:rgba(45,122,79,.07);border-color:rgba(45,122,79,.25)} .tip .ci{color:#2d7a4f}
    .info{background:rgba(59,130,246,.07);border-color:rgba(59,130,246,.25)} .info .ci{color:#3b82f6}
    .warn{background:rgba(180,83,9,.07);border-color:rgba(180,83,9,.25)} .warn .ci{color:#b45309}
  </style>
</head>
<body>
  <div id="pb"></div>

  <header>
    <div class="hi">
      <div class="hl">
        <button id="mbtn" class="ibtn" aria-label="選單">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
        <a href={`${base}/`} class="site-name">
          <span class="logo">CC</span>&nbsp;&nbsp;Claude Code 完整指南
        </a>
      </div>
      <div class="hr">
        <button id="tt" class="ibtn" aria-label="切換主題">
          <svg id="isun" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" style="display:none">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364-.707-.707M6.343 6.343l-.707-.707m12.728 0-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0z"/>
          </svg>
          <svg id="imoon" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 0 1 8.646 3.646 9.003 9.003 0 0 0 12 21a9.003 9.003 0 0 0 8.354-5.646z"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <div id="layout">
    <nav id="sb">
      {navigation.map((part) => {
        const open = isPartOpen(part);
        return (
          <div class="np">
            <button class={`pt${open ? ' open' : ''}`} data-pid={part.part}>
              <span>Part {part.part}：{part.partTitle}</span>
              <svg class="arr" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            </button>
            <ul class={`nl${open ? '' : ' closed'}`} data-pl={part.part}>
              {part.chapters.map((ch) => (
                <li>
                  <a
                    href={ch.comingSoon ? undefined : `${base}/${ch.slug}`}
                    class={[
                      currentSlug === ch.slug ? 'active' : '',
                      ch.comingSoon ? 'cs' : '',
                    ].filter(Boolean).join(' ') || undefined}
                  >
                    <span class="cn">{ch.num}.</span>
                    <span>{ch.title}</span>
                    {ch.comingSoon && <span class="bs">即將推出</span>}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        );
      })}
    </nav>

    <div id="ov"></div>

    <main>
      <div class="cb">
        <slot />
      </div>

      <nav class="cnav">
        {prevChapter
          ? <a href={`${base}/${prevChapter.slug}`} class="prev">
              <span class="nd">← 上一章</span>
              <span class="nt">{prevChapter.title}</span>
            </a>
          : <div class="ph"></div>}
        {nextChapter
          ? <a href={`${base}/${nextChapter.slug}`} class="next">
              <span class="nd">下一章 →</span>
              <span class="nt">{nextChapter.title}</span>
            </a>
          : <div class="ph"></div>}
      </nav>
    </main>
  </div>

  <script is:inline>
    // Theme
    const html = document.documentElement;
    const tt = document.getElementById('tt');
    const isun = document.getElementById('isun');
    const imoon = document.getElementById('imoon');
    function syncIcons() {
      const dk = html.classList.contains('dark');
      isun.style.display = dk ? 'block' : 'none';
      imoon.style.display = dk ? 'none' : 'block';
    }
    syncIcons();
    tt?.addEventListener('click', () => {
      html.classList.toggle('dark');
      localStorage.setItem('cc-theme', html.classList.contains('dark') ? 'dark' : 'light');
      syncIcons();
    });

    // Progress
    const pb = document.getElementById('pb');
    window.addEventListener('scroll', () => {
      const t = document.documentElement.scrollHeight - window.innerHeight;
      pb.style.width = t > 0 ? `${(window.scrollY / t) * 100}%` : '0%';
    }, { passive: true });

    // Sidebar part toggles
    document.querySelectorAll('.pt').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.pid;
        const list = document.querySelector(`[data-pl="${id}"]`);
        btn.classList.toggle('open');
        list?.classList.toggle('closed');
      });
    });

    // Mobile menu
    const sb = document.getElementById('sb');
    const ov = document.getElementById('ov');
    const mb = document.getElementById('mbtn');
    const open = () => { sb.classList.add('open'); ov.classList.add('open'); document.body.style.overflow='hidden'; };
    const close = () => { sb.classList.remove('open'); ov.classList.remove('open'); document.body.style.overflow=''; };
    mb?.addEventListener('click', open);
    ov?.addEventListener('click', close);
  </script>
</body>
</html>
